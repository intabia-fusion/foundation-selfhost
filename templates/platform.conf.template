PLATFORM_VERSION=${PLATFORM_VERSION}
DESKTOP_CHANNEL=${DESKTOP_CHANNEL}
DOCKER_NAME=${DOCKER_NAME:-platform}
DEV_MODE=${DEV_MODE}

# The address of the host or server from which you will access your Platform instance.
# This can be a domain name (e.g., platform.example.com) or an IP address (e.g., 192.168.1.1).
HOST_ADDRESS=${HOST_ADDRESS}

# Set this variable to 'true' to enable SSL (HTTPS/WSS).
# Leave it empty to use non-SSL (HTTP/WS).
SECURE=${SECURE}

# Specify the IP address to bind to; leave blank to bind to all interfaces (0.0.0.0).
# Do not use IP:PORT format in HTTP_BIND or HTTP_PORT.
HTTP_PORT=${HTTP_PORT}
HTTP_BIND=${HTTP_BIND}

# Platform specific variables
TITLE=${TITLE}
DEFAULT_LANGUAGE=${DEFAULT_LANGUAGE}
LAST_NAME_FIRST=${LAST_NAME_FIRST}

# PostgreSQL variables
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_SECRET}
CR_DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_SECRET}@postgres:5432/${POSTGRES_DB}

# Redpanda variables
REDPANDA_ADMIN_USER=${REDPANDA_ADMIN_USER}
REDPANDA_ADMIN_PWD=${REDPANDA_SECRET}

# Docker volume paths - persistent data storage locations
# By default, data is stored in ./data/ subdirectories
# Set to empty to use Docker named volumes instead
VOLUME_ELASTIC_PATH=${VOLUME_ELASTIC_PATH}
VOLUME_FILES_PATH=${VOLUME_FILES_PATH}
VOLUME_POSTGRES_DATA_PATH=${VOLUME_POSTGRES_DATA_PATH}
VOLUME_REDPANDA_PATH=${VOLUME_REDPANDA_PATH}
VOLUME_MAILPIT_PATH=${VOLUME_MAILPIT_PATH}

# Mailpit web UI port (for viewing captured emails)
MAILPIT_HTTP_PORT=${MAILPIT_HTTP_PORT:-8025}

# The following configs are auto-generated by the setup script.
# Please do not manually overwrite.
SECRET=${PLATFORM_SECRET}
STORAGE_CONFIG="${STORAGE_CONFIG}"

LIVEKIT_HOST=${LIVEKIT_HOST}
LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}
LIVEKIT_ENABLED=${LIVEKIT_ENABLED}
LIVEKIT_TURN_DOMAIN=${LIVEKIT_TURN_DOMAIN}

# STT (Speech-to-Text) configuration for AI Bot
STT_PROVIDER=${STT_PROVIDER}
STT_URL=${STT_URL}
STT_API_KEY=${STT_API_KEY}
STT_MODEL=${STT_MODEL}

# OpenAI configuration for AI Bot
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_BASE_URL=${OPENAI_BASE_URL}
OPENAI_SUMMARY_MODEL=${OPENAI_SUMMARY_MODEL}
OPENAI_TRANSLATE_MODEL=${OPENAI_TRANSLATE_MODEL}

# Push notification keys for notification service
PUSH_PUBLIC_KEY=${PUSH_PUBLIC_KEY:-}
PUSH_PRIVATE_KEY=${PUSH_PRIVATE_KEY:-}
